# =============================================================================
# Reference Nginx reverse-proxy config for PlanNight (Hetzner/Ubuntu).
#
# Assumes:
#   * The API container publishes 127.0.0.1:4000 on the host.
#   * Certbot/Let's Encrypt manages the certs (run `certbot --nginx`).
#
# Place at /etc/nginx/sites-available/plannight and symlink into sites-enabled,
# then: nginx -t && systemctl reload nginx
# =============================================================================

# Redirect all HTTP to HTTPS.
server {
    listen 80;
    listen [::]:80;
    server_name api.example.com;   # <-- change to your domain

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.example.com;   # <-- change to your domain

    # Certbot fills these in when you run `certbot --nginx`.
    ssl_certificate     /etc/letsencrypt/live/api.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.example.com/privkey.pem;

    # Reasonable modern TLS defaults.
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # Body limit matches the API's express.json limit.
    client_max_body_size 1m;

    location / {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;

        # Preserve client info so the app's `trust proxy` sees the real IP.
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 30s;
    }
}
