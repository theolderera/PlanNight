/android/app/debug
/android/app/profile
/android/app/release

# `flutter gen-l10n` writes this report of ARB keys missing from a locale. It
# should always be `{}` — check it after touching the ARB files, don't commit it.
l10n_untranslated.json

# Verbose logs the flutter tool drops in the project root.
flutter_*.log
