{
  "name": "plannight-backend",
  "version": "0.1.0",
  "description": "REST API for PlanNight — a time-scheduled daily task planner & discipline tracker.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "start:dev": "node --watch src/server.js",
    "migrate": "node src/db/migrate.js up",
    "migrate:status": "node src/db/migrate.js status"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  }
}
