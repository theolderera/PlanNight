# ---------------------------------------------------------------------------
# PlanNight backend environment variables
# Copy this file to `.env` and fill in real values. NEVER commit your real .env.
# ---------------------------------------------------------------------------

# HTTP server
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins. Use * only in development.
CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# PostgreSQL connection
# These values are for running the API on your HOST (`npm run dev`). Under
# docker-compose the api/migrate services override DB_HOST/DB_PORT to reach the
# `db` service inside the network, so you don't need to edit them when switching.
#
# DB_PORT is 5433 because that is where compose publishes the Postgres container
# (see docker-compose.yml). 5432 is left to any natively-installed PostgreSQL —
# connecting there by mistake gives a baffling "password authentication failed".
#
# A single DATABASE_URL, if set, takes precedence over the individual DB_* values.
# ---------------------------------------------------------------------------
# DATABASE_URL=postgres://plannight:plannight@localhost:5433/plannight
DB_HOST=localhost
DB_PORT=5433
DB_USER=plannight
DB_PASSWORD=plannight
DB_NAME=plannight
# Set to "true" to require TLS to the database (e.g. some managed providers).
DB_SSL=false

# ---------------------------------------------------------------------------
# Authentication (JWT)
# Generate strong secrets, e.g.:  openssl rand -hex 48
# ACCESS and REFRESH secrets MUST be different.
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cost factor for bcrypt password hashing (10-12 is a good range).
BCRYPT_ROUNDS=12
