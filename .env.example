# =============================================================================
# Root .env — read by Docker Compose ONLY (for ${...} interpolation).
#
# Copy to `.env` and change the password before deploying:
#     cp .env.example .env
#
# Compose does not read backend/.env for interpolation, so these values are the
# single source of truth for the database credentials: they both initialise the
# Postgres container AND get injected into the api/migrate containers.
# Application secrets (JWT, bcrypt rounds) live in backend/.env instead.
# =============================================================================

DB_USER=plannight
DB_PASSWORD=plannight
DB_NAME=plannight

# Host port the Postgres container is published on. NOT 5432 by default: if a
# PostgreSQL is installed natively on this machine it already owns 5432, and
# Docker fails to bind it without complaining. Anything on the host that then
# connects to 5432 reaches the *other* server and fails to authenticate.
# Inside the compose network the containers always talk to db:5432.
DB_PORT_HOST=5433

# Host port the API is published on.
PORT=4000

# Which interface the API binds to on the host.
#   0.0.0.0   — local dev: reachable from the LAN / adb reverse.
#   127.0.0.1 — production: only the host nginx (HTTPS terminator) reaches it.
API_BIND=0.0.0.0

# 'production' on a server, 'development' locally.
NODE_ENV=production
